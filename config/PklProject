  baseUri = "package://github.com/bmurray/circadian/config"
  version = "0.1.0"
  packageZipUrl = "https://github.com/bmurray/circadian/releases/download/config@\(version)/config@\(version).zip"
  authors {
    "bmurray <bmurray@users.noreply.github.com>"
  }
  license = "MIT"
  description = "Configuration schema for Circadian timezone comparison app"
