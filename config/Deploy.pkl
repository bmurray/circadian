/// Deploy orchestrator for Circadian.
/// Import this file, set your config values, and evaluate to produce
/// output files for k8s and compose.
module Deploy

import "Config.pkl"
import "deploy/compose/ComposeStack.pkl"

import "@devops-shared/Web.pkl"
import "@devops-shared/Gateway.pkl"
import "@devops-shared/HTTP.pkl"

/// The application configuration. Override with your deployment values.
appConfig: Config = new Config {
  image {
    repository = "ghcr.io/bmurray/circadian"
    tag = "latest"
  }
  domains {
    "circadian.example.com"
  }
  nginx {}
  resources {
    requests {
      cpu = "50m"
      memory = "32Mi"
    }
    limits {
      cpu = "200m"
      memory = "64Mi"
    }
  }
}

appName: String = "circadian"
appPort: Int = 80

hidden appLabels = Web.appLabels(appName)
hidden image = "\(appConfig.image.repository):\(appConfig.image.tag)"

hidden redirectDomains: Listing<String> = if (appConfig.redirects == null) new Listing {}
  else new Listing {
    for (from, _ in appConfig.redirects!!) {
      from
    }
  }

hidden allDomains: Listing<String> = new {
  ...appConfig.domains
  ...redirectDomains
}

hidden gw = Gateway.gateway(
  "circadian-gateway",
  appConfig.namespace,
  appConfig.gatewayClassName,
  appConfig.clusterIssuer,
  allDomains,
)

/// All Kubernetes manifests as a single list.
k8sManifests: Listing = new {
  Web.namespace(appConfig.namespace)
  gw
  Web.service(appName, appConfig.namespace, appPort, appLabels)
  Web.deployment(appName, appConfig.namespace, image, appConfig.replicas.toInt(), appPort, appLabels)
  ...HTTP.routes(appName, gw, appConfig.domains, redirectDomains)
}

/// Compose stack config.
compose: ComposeStack = new ComposeStack {
  appConfig = outer.appConfig
}

composeManifest = compose.compose()

/// Output targets — evaluate with `pkl eval -m . Deploy.pkl`
output {
  files {
    ["k8s/manifests.yaml"] {
      renderer = new YamlRenderer { isStream = true }
      value = k8sManifests
    }
    ["compose/docker-compose.yaml"] {
      renderer = new YamlRenderer {}
      value = composeManifest
    }
  }
}
